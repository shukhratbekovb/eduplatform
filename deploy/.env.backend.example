# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false
ALLOWED_ORIGINS=["https://shukhratbekov.uz","https://crm.shukhratbekov.uz","https://lms.shukhratbekov.uz","https://student.shukhratbekov.uz"]

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://edu:CHANGE_ME_DB_PASSWORD@postgres:5432/eduplatform

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# ── Celery / RabbitMQ ─────────────────────────────────────────────────────────
CELERY_BROKER_URL=amqp://edu:CHANGE_ME_RABBITMQ_PASSWORD@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/1

# ── MinIO ─────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=CHANGE_ME_MINIO_PASSWORD
AWS_BUCKET_NAME=eduplatform-files
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://minio:9000

GCS_CREDENTIALS_JSON=/app/gcp_keys.json
